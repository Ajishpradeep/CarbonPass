# Copy to .env and fill in. .env is gitignored.

# MOENV open-data API key (data.moenv.gov.tw) — optional; static snapshot in data/ef/ works without it
MOENV_API_KEY=

# Model serving (Ollama default)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3-vl:8b-instruct

# LINE Messaging API (Module 3 — needed when the bot is built, not for Sprint 0-1)
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# Paths
CBAM_OFFICIAL_DIR=data/cbam_official
EF_DIR=data/ef
